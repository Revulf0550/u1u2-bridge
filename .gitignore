# Large firmware images (kept locally only)
firmware/

# Python ephemeral
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/

# Secrets — никогда не коммитим WG-конфиги
*-pi.conf
wg0.conf
*.privatekey

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# WireGuard configs — содержат приватные ключи и PSK, никогда не коммитить
*.conf
!docs/wg-template.conf

# Firmware images (большие бинарники, не в репо)
firmware/*.img
firmware/*.img.xz
firmware/*.img.gz
